# ── Palworld server config (PUBLIC — this is your config-as-code) ──
# Every value maps 1:1 to PalWorldSettings.ini. Changing a setting = a public,
# signed commit. The audit workflow ENFORCES the three admin locks below on
# every push, so no commit can quietly re-enable admin.

# ═══════════════ ADMIN LOCKS — do not change ═══════════════
# These three are Palworld's ENTIRE admin surface. With all three off, there is
# no way for anyone (including the host) to issue an admin/cheat command.
ADMIN_PASSWORD=
RCON_ENABLED=false
REST_API_ENABLED=false
# ═══════════════════════════════════════════════════════════

# Identity
SERVER_NAME=RageQuit-Palworld
SERVER_DESCRIPTION=No admin. Config is public + audited. See TRUST.md.
COMMUNITY_SERVER=true
MULTITHREADING=true
PLAYERS=16

# JOIN password — gates who can connect. NOT an admin credential (grants zero
# privileges, irrelevant to fairness). Kept PRIVATE: the real value lives in
# game.local.env on the host (gitignored), never in this public file.
SERVER_PASSWORD=

# Keep the running build matched to the pinned image + approved config.
AUTO_UPDATE_ENABLED=false
BACKUP_ENABLED=true

# ─────────────── Gameplay settings (change via pull request) ───────────────
DIFFICULTY=None
DEATH_PENALTY=All
PVP=false
EXP_RATE=1.0
PAL_CAPTURE_RATE=1.0
PAL_SPAWN_NUM_RATE=1.0
DAY_TIME_SPEED_RATE=1.0
NIGHT_TIME_SPEED_RATE=1.0
