# ── Compose substitution vars (PUBLIC — no secrets belong in this file) ──

# Pin the image by DIGEST for immutability (not a moving tag). Get the digest:
#   docker buildx imagetools inspect thijsvanloef/palworld-server-docker:v0.42.0
# then paste the sha256 below. The audit workflow FAILS if this isn't a digest.
PALWORLD_IMAGE=thijsvanloef/palworld-server-docker@sha256:ae412908f99ed5422bb977d152838a6e2f5d1a6f1f5191a7d24217dcaccb7046

# Host paths & runtime identity
SAVE_DIR=./saves
PUID=1000
PGID=1000
TZ=UTC

# Ports. Only the game (and optional query) port is exposed.
GAME_PORT=8211
QUERY_PORT=27015
