# ── Host-only watcher config — copy to watcher.env and DO NOT commit ──
# The watcher discovers games from games/*/manifest.json, so per-game details are
# not set here.

# Real-time alert channel (Server Settings > Integrations > Webhooks in Discord)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXX/YYYY

# Where this repo is checked out on the VM (the source of truth for CONFIG the
# watcher reads). Kept up to date by ./scripts/deploy.sh.
REPO_DIR=/opt/selfhostgameservers

# Heartbeats are pushed to a SEPARATE branch so `main` can be branch-protected
# (require-PR / require-signed-commits) without blocking the watcher. Use a
# separate checkout OWNED BY the watcher user, using its repo-scoped deploy key.
# One-time setup on the VM (as the gameservers-watcher user):
#   git clone git@github.com:ShackledSanity/selfhostgameservers.git ~/hb-repo
#   git -C ~/hb-repo checkout -B heartbeat
HEARTBEAT_PUSH=true
HEARTBEAT_REPO=/home/gameservers-watcher/hb-repo
HEARTBEAT_BRANCH=heartbeat
GIT_REMOTE=origin

# Intervals (seconds)
CHECK_INTERVAL=60
PUSH_INTERVAL=300
